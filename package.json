{
  "name": "building-management-backend",
  "version": "0.1.0",
  "description": "Building Management System Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/server.ts",
    "build": "tsc; tsc-alias",
    "start": "npx prisma db push --skip-generate && node dist/server.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:coverage": "jest --coverage --forceExit",
    "test:manual": "bash tests/phase2-endpoints.sh",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "create-admin": "ts-node -r tsconfig-paths/register scripts/create-admin-user.ts",
    "validate-env": "ts-node -r tsconfig-paths/register scripts/validate-env.ts",
    "seed-admin": "ts-node -r tsconfig-paths/register prisma/seed-admin.ts"
  },
  "keywords": [
    "building",
    "management",
    "api",
    "express",
    "typescript"
  ],
  "author": "María Alejandra",
  "license": "PROPRIETARY",
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.2.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.10",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "prisma": "^5.7.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
