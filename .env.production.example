# BuildHub Production Environment Variables
# Copy to .env.production and fill in actual values
# NEVER commit actual secrets - use secure vault (AWS Secrets Manager, HashiCorp Vault, etc)

# ==============================================================================
# DATABASE
# ==============================================================================
# Production MySQL connection string (use AWS RDS or similar managed service)
# Format: mysql://username:password@host:port/database
# SECURITY: Use strong password (20+ chars, uppercase, lowercase, numbers, symbols)
DATABASE_URL="mysql://prod_user:SecurePassword123!@prod-db.rds.amazonaws.com:3306/buildhub"

# ==============================================================================
# SERVER
# ==============================================================================
# Environment (always "production" in prod)
NODE_ENV="production"

# Server port (usually proxied by nginx/load balancer)
PORT="3001"

# Public API URL (used in emails, redirects, etc)
API_URL="https://api.buildhub.casa"

# ==============================================================================
# JWT AUTHENTICATION (Phase 2)
# ==============================================================================
# Generate with: openssl rand -hex 32
# SECURITY: Must be UNIQUE for each environment
# SECURITY: Rotate regularly, update clients gracefully
ACCESS_TOKEN_SECRET="your-super-secret-access-key-min-32-characters-production"
ADMIN_TOKEN_SECRET="your-super-secret-admin-key-min-32-characters-production"
REFRESH_TOKEN_SECRET="your-super-secret-refresh-key-min-32-characters-production"

# ==============================================================================
# CORS (Cross-Origin Resource Sharing)
# ==============================================================================
# Comma-separated list of allowed frontend origins
# SECURITY: Be specific, never use "*" in production
CORS_ORIGIN="https://buildhub.casa,https://admin.buildhub.casa,https://www.buildhub.casa"

# ==============================================================================
# EMAIL SERVICE (SendGrid)
# ==============================================================================
# SendGrid API key from https://app.sendgrid.com/settings/api_keys
# SECURITY: Use API key with restricted permissions (Mail Send only)
SENDGRID_API_KEY="SG.your-actual-sendgrid-api-key"

# From email address (must be verified in SendGrid)
SENDGRID_FROM_EMAIL="noreply@buildhub.casa"

# ==============================================================================
# FILE UPLOADS
# ==============================================================================
# Directory for uploaded files (should be on persistent storage like S3, not local)
# RECOMMENDED: Use AWS S3 or similar for scalability
# Local paths don't work well in multi-server deployments
UPLOAD_DIR="/var/buildhub/uploads"

# Maximum file size in bytes (10MB)
MAX_FILE_SIZE="10485760"

# ==============================================================================
# LOGGING & MONITORING
# ==============================================================================
# Log level: error, warn, info, debug
# PRODUCTION: Use "warn" or "info" (not "debug", too verbose)
LOG_LEVEL="info"

# Sentry error tracking (optional but recommended)
# Get from: https://sentry.io/settings/...
# SECURITY: Read-only DSN, public key only
SENTRY_DSN="https://xxxxx@sentry.io/project-id"

# ==============================================================================
# SECURITY HEADERS
# ==============================================================================
# HTTPS enforcement (set in nginx/load balancer, not here)
# All traffic should be HTTPS only in production

# ==============================================================================
# OPTIONAL: ADVANCED CONFIGURATION
# ==============================================================================

# Database connection pool size (Prisma)
# RECOMMENDED: 10-20 for production
DATABASE_POOL_MIN="5"
DATABASE_POOL_MAX="20"

# Rate limiting (future feature)
RATE_LIMIT_WINDOW_MS="900000"      # 15 minutes
RATE_LIMIT_MAX_REQUESTS="100"      # per window

# Session timeout (Phase 2)
SESSION_TIMEOUT_MS="3600000"       # 1 hour

# ==============================================================================
# IMPORTANT NOTES
# ==============================================================================
#
# 1. SECURITY CHECKLIST:
#    ✓ Change all example values to actual production values
#    ✓ Generate strong random secrets (openssl rand -hex 32)
#    ✓ Use managed database (AWS RDS, Google Cloud SQL, etc)
#    ✓ Enable HTTPS/TLS everywhere
#    ✓ Use strong database password (20+ chars)
#    ✓ Store secrets in vault, NOT in .env file
#    ✓ Never commit this file with real secrets
#    ✓ Rotate secrets monthly
#    ✓ Use IAM roles for AWS access, not access keys
#
# 2. DATABASE:
#    ✓ Use managed database service (auto-backups, high availability)
#    ✓ Enable multi-AZ replication
#    ✓ Regular automated backups (daily minimum)
#    ✓ Test restore procedures quarterly
#    ✓ Enable encryption at rest
#    ✓ Use VPC/private networking
#
# 3. FILE UPLOADS:
#    ✓ Do NOT use local filesystem in production
#    ✓ Use AWS S3, Google Cloud Storage, or similar
#    ✓ Enable bucket encryption
#    ✓ Restrict public access
#    ✓ Enable versioning for recovery
#
# 4. MONITORING:
#    ✓ Set up Sentry for error tracking
#    ✓ Enable CloudWatch/Stackdriver logging
#    ✓ Set up alerts for errors, high latency
#    ✓ Monitor database performance
#    ✓ Set up uptime monitoring (UptimeRobot, Pingdom)
#
# 5. DEPLOYMENT:
#    ✓ Use infrastructure-as-code (Terraform, CloudFormation)
#    ✓ Automate database migrations in CI/CD
#    ✓ Use container orchestration (Kubernetes, ECS)
#    ✓ Zero-downtime deployments
#    ✓ Automated rollbacks on failure
#
# ==============================================================================
