// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// BuildHub Company & Multi-Tenant
// ============================================

model B2BClient {
  id                String   @id @default(uuid()) @db.Char(36)
  companyName       String   @unique @db.VarChar(255)
  subdomain         String   @unique @db.VarChar(100)
  accountType       AccountType
  status            ClientStatus @default(ACTIVE)

  // Quotas
  userQuota         Int
  buildingQuota     Int? // null if BUILDING type

  // Payment
  paymentPlan       String   @db.VarChar(100)
  paymentAccessRole String   @db.VarChar(50)

  // Contract
  contractStartDate DateTime
  contractEndDate   DateTime

  // Relations
  buildings         Building[]
  deletionRequests  ClientDeletionRequest[]
  supportTickets    SupportTicket[]
  boardMembers      BoardMember[]
  generalMeetings   GeneralMeeting[]
  financialDocuments FinancialDocument[]
  buildingExpenses  BuildingExpense[]
  amenities         ComplexAmenity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subdomain])
  @@index([status])
}

enum AccountType {
  BUILDING
  ADCOMPLEX
}

enum ClientStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

model BuildHubAdminUser {
  id        String   @id @default(uuid()) @db.Char(36)
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  firstName String   @db.VarChar(100)
  lastName  String   @db.VarChar(100)
  role      AdminRole
  status    AdminStatus @default(ACTIVE)

  // Relations
  sentDeletionRequests ClientDeletionRequest[] @relation("requestedBy")
  approvedDeletionRequests ClientDeletionRequest[] @relation("approvedBy")
  assignedTickets SupportTicket[]
  passwordResetLogs PasswordResetLog[] @relation("resetBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
}

enum AdminRole {
  SUPERADMIN
  ADMIN_DASHBOARD
}

enum AdminStatus {
  ACTIVE
  INACTIVE
}

model ClientDeletionRequest {
  id         String   @id @default(uuid()) @db.Char(36)
  clientId   String   @db.Char(36)
  requestedById String  @db.Char(36)
  status     DeletionRequestStatus @default(PENDING)

  reason     String   @db.VarChar(500)
  approvedById String? @db.Char(36)
  approvalNotes String?

  // Relations
  client    B2BClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  requestedBy BuildHubAdminUser @relation("requestedBy", fields: [requestedById], references: [id], onDelete: Cascade)
  approvedBy BuildHubAdminUser? @relation("approvedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  approvedAt DateTime?
  deletedAt DateTime?

  @@index([clientId])
  @@index([status])
}

enum DeletionRequestStatus {
  PENDING
  APPROVED
  REJECTED
  DELETED
}

model PasswordResetLog {
  id         String   @id @default(uuid()) @db.Char(36)
  userId     String?  @db.Char(36)
  resetById  String   @db.Char(36)
  resetByRole String   @db.VarChar(50)

  userEmail  String   @db.VarChar(255)
  userRole   String   @db.VarChar(50)

  // Relations
  user      User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  resetBy   BuildHubAdminUser @relation("resetBy", fields: [resetById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([resetById])
}

// ============================================
// User & Authentication
// ============================================

model User {
  id        String   @id @default(uuid()) @db.Char(36)
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  firstName String   @db.VarChar(100)
  lastName  String   @db.VarChar(100)
  phone     String?  @db.VarChar(20)
  role      UserRole @default(OWNER)
  status    UserStatus @default(PENDING_VERIFICATION)

  // Relations
  buildingMembers  BuildingMember[]
  apartmentOwners  ApartmentOwner[]
  createdAnnouncements Announcement[]
  createdMaintenanceRequests MaintenanceRequest[]
  assignedMaintenanceRequests MaintenanceRequest[] @relation("assignedTo")
  uploadedReports Report[]
  auditLogs AuditLog[]
  sentInvitations Invitation[] @relation("invitedBy")
  acceptedInvitations Invitation[] @relation("acceptedBy")
  boardMemberships BoardMember[]
  createdMeetings GeneralMeeting[] @relation("createdBy")
  uploadedDocuments FinancialDocument[] @relation("uploadedBy")
  submittedTickets SupportTicket[] @relation("submittedBy")
  passwordResetLogs PasswordResetLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
}

// ============================================
// Invitations
// ============================================

model Invitation {
  id           String   @id @default(uuid()) @db.Char(36)
  token        String   @unique @db.VarChar(255)
  email        String   @db.VarChar(255)
  buildingId   String   @db.Char(36)
  invitedRole  BuildingRole
  invitedById  String   @db.Char(36)
  acceptedById String?  @db.Char(36)
  expiresAt    DateTime

  // Relations
  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  invitedBy User    @relation("invitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedBy User?   @relation("acceptedBy", fields: [acceptedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([buildingId])
  @@index([expiresAt])
}

enum UserRole {
  OWNER
  ADMIN
  BOARD_MEMBER
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  INACTIVE
}

// ============================================
// Buildings & Apartments
// ============================================

model Building {
  id              String   @id @default(uuid()) @db.Char(36)
  clientId        String   @db.Char(36)
  name            String   @db.VarChar(255)
  address         String   @db.VarChar(500)
  city            String   @db.VarChar(100)
  postalCode      String?  @db.VarChar(20)
  country         String   @default("Colombia") @db.VarChar(100)
  totalApartments Int
  yearBuilt       Int?
  description     String?
  status          BuildingStatus @default(ACTIVE)

  // Relations
  client           B2BClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  members          BuildingMember[]
  apartments       Apartment[]
  announcements    Announcement[]
  fees             Fee[]
  reports          Report[]
  financialSummaries FinancialSummary[]
  auditLogs        AuditLog[]
  invitations      Invitation[]
  boardMembers     BoardMember[]
  generalMeetings  GeneralMeeting[]
  expenses         BuildingExpense[]
  financialDocs    FinancialDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([name])
}

enum BuildingStatus {
  ACTIVE
  INACTIVE
}

model Apartment {
  id        String   @id @default(uuid()) @db.Char(36)
  buildingId String   @db.Char(36)
  unitNumber String   @db.VarChar(50)
  floor     Int?
  bedrooms  Int?
  bathrooms Decimal? @db.Decimal(3, 1)
  areaSqm   Decimal? @db.Decimal(8, 2)
  status    ApartmentStatus @default(OCCUPIED)

  // Relations
  building  Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  owners    ApartmentOwner[]
  fees      Fee[]
  payments  Payment[]
  maintenanceRequests MaintenanceRequest[]
  financialSummaries FinancialSummary[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([buildingId, unitNumber])
  @@index([buildingId])
}

enum ApartmentStatus {
  OCCUPIED
  VACANT
  MAINTENANCE
}

model BuildingMember {
  id         String   @id @default(uuid()) @db.Char(36)
  buildingId String   @db.Char(36)
  userId     String   @db.Char(36)
  role       BuildingRole
  status     MemberStatus @default(ACTIVE)
  joinedAt   DateTime @default(now())
  invitedAt  DateTime?

  // Relations
  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([buildingId, userId])
  @@index([buildingId])
  @@index([userId])
}

enum BuildingRole {
  OWNER
  ADMIN
  BOARD_MEMBER
}

enum MemberStatus {
  PENDING
  ACTIVE
  INACTIVE
}

model ApartmentOwner {
  id                 String   @id @default(uuid()) @db.Char(36)
  apartmentId        String   @db.Char(36)
  ownerId            String   @db.Char(36)
  ownershipPercentage Decimal @default(100) @db.Decimal(5, 2)
  ownershipType      OwnershipType
  status             OwnershipStatus @default(ACTIVE)
  startedAt          DateTime @default(now())
  endedAt            DateTime?

  // Relations
  apartment Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  owner     User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([apartmentId, ownerId])
  @@index([apartmentId])
  @@index([ownerId])
}

enum OwnershipType {
  FULL_OWNER
  CO_OWNER
  TENANT
}

enum OwnershipStatus {
  ACTIVE
  INACTIVE
}

// ============================================
// Communication
// ============================================

model Announcement {
  id        String   @id @default(uuid()) @db.Char(36)
  buildingId String   @db.Char(36)
  createdById String?  @db.Char(36)
  title     String   @db.VarChar(255)
  content   String
  visibility AnnouncementVisibility @default(ALL_RESIDENTS)
  priority  AnnouncementPriority @default(NORMAL)

  // Relations
  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  createdBy User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buildingId])
  @@index([createdAt])
}

enum AnnouncementVisibility {
  ALL_RESIDENTS
  OWNERS_ONLY
  BOARD_ONLY
}

enum AnnouncementPriority {
  LOW
  NORMAL
  URGENT
}

model MaintenanceRequest {
  id         String   @id @default(uuid()) @db.Char(36)
  apartmentId String   @db.Char(36)
  createdById String?  @db.Char(36)
  assignedToId String? @db.Char(36)
  title      String   @db.VarChar(255)
  description String
  category   String?  @db.VarChar(50)
  priority   MaintenancePriority @default(MEDIUM)
  status     MaintenanceStatus @default(OPEN)

  // Relations
  apartment Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  createdBy User?      @relation(fields: [createdById], references: [id], onDelete: SetNull)
  assignedTo User?    @relation("assignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([apartmentId])
  @@index([status])
  @@index([assignedToId])
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

enum MaintenanceStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CLOSED
}

// ============================================
// Financial
// ============================================

model Fee {
  id          String   @id @default(uuid()) @db.Char(36)
  buildingId  String   @db.Char(36)
  apartmentId String?  @db.Char(36)
  type        String   @db.VarChar(50)
  amount      Decimal  @db.Decimal(10, 2)
  dueDate     DateTime?
  paidDate    DateTime?
  status      FeeStatus @default(PENDING)
  description String?

  // Relations
  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  apartment Apartment? @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buildingId])
  @@index([apartmentId])
  @@index([status])
  @@index([dueDate])
}

enum FeeStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
}

model Payment {
  id           String   @id @default(uuid()) @db.Char(36)
  apartmentId  String   @db.Char(36)
  feeId        String?  @db.Char(36)
  amount       Decimal  @db.Decimal(10, 2)
  paymentDate  DateTime @default(now())
  paymentMethod String?  @db.VarChar(50)
  status       PaymentStatus @default(PENDING)
  reference    String?

  // Relations
  apartment Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  fee       Fee?      @relation(fields: [feeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([apartmentId])
  @@index([feeId])
  @@index([paymentDate])
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

model FinancialSummary {
  id              String   @id @default(uuid()) @db.Char(36)
  buildingId      String   @db.Char(36)
  apartmentId     String?  @db.Char(36)
  totalFees       Decimal  @db.Decimal(12, 2)
  totalPaid       Decimal  @db.Decimal(12, 2)
  outstanding     Decimal  @db.Decimal(12, 2)
  period          String   @db.VarChar(7) // "YYYY-MM"

  // Relations
  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  apartment Apartment? @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buildingId])
  @@index([period])
}

// ============================================
// Reports & Documents
// ============================================

model Report {
  id         String   @id @default(uuid()) @db.Char(36)
  buildingId String   @db.Char(36)
  uploadedById String?  @db.Char(36)
  fileName   String   @db.VarChar(255)
  filePath   String
  fileType   String   @db.VarChar(50)
  fileSize   Int
  reportType ReportType
  description String?

  // Relations
  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  uploadedBy User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buildingId])
  @@index([reportType])
}

enum ReportType {
  MEETING_MINUTES
  MAINTENANCE_LOG
  FINANCIAL_STATEMENT
  OTHER
}

// ============================================
// Audit & Logging
// ============================================

model AuditLog {
  id         String   @id @default(uuid()) @db.Char(36)
  userId     String?  @db.Char(36)
  buildingId String?  @db.Char(36)
  action     String   @db.VarChar(255)
  entityType String?  @db.VarChar(100)
  entityId   String?  @db.Char(36)
  changes    Json?
  ipAddress  String?  @db.VarChar(45)

  // Relations
  user User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  building Building? @relation(fields: [buildingId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([buildingId])
  @@index([createdAt])
}

// ============================================
// Board & Meetings
// ============================================

model BoardMember {
  id         String   @id @default(uuid()) @db.Char(36)
  userId     String   @db.Char(36)
  buildingId String   @db.Char(36)
  clientId   String   @db.Char(36)

  title      String   @db.VarChar(100)
  joinedDate DateTime @default(now())
  termStart  DateTime
  termEnd    DateTime?

  // Relations
  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  client     B2BClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, buildingId])
  @@index([buildingId])
  @@index([userId])
  @@index([clientId])
}

model GeneralMeeting {
  id          String   @id @default(uuid()) @db.Char(36)
  buildingId  String   @db.Char(36)
  clientId    String   @db.Char(36)

  title       String   @db.VarChar(255)
  description String?
  meetingDate DateTime
  location    String?

  status      MeetingStatus @default(SCHEDULED)

  createdById String  @db.Char(36)
  minutesDocId String? @unique @db.Char(36)

  // Relations
  building    Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  client      B2BClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy   User @relation("createdBy", fields: [createdById], references: [id], onDelete: Cascade)
  minutesDoc  FinancialDocument? @relation("meetingMinutes", fields: [minutesDocId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buildingId])
  @@index([clientId])
  @@index([meetingDate])
}

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

// ============================================
// Financial Documents & Expenses
// ============================================

model FinancialDocument {
  id         String   @id @default(uuid()) @db.Char(36)
  buildingId String   @db.Char(36)
  clientId   String   @db.Char(36)

  fileName   String   @db.VarChar(255)
  filePath   String
  fileType   String   @db.VarChar(50)
  fileSize   Int

  documentType DocumentType
  description  String?

  uploadedById String @db.Char(36)

  // Relations
  building     Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  client       B2BClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  uploadedBy   User @relation("uploadedBy", fields: [uploadedById], references: [id], onDelete: Cascade)
  meetingMinutes GeneralMeeting? @relation("meetingMinutes")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buildingId])
  @@index([clientId])
  @@index([documentType])
}

enum DocumentType {
  MEETING_MINUTES
  FINANCIAL_STATEMENT
  BUDGET
  AUDIT_REPORT
  INSURANCE
  OTHER
}

model BuildingExpense {
  id         String   @id @default(uuid()) @db.Char(36)
  buildingId String   @db.Char(36)
  clientId   String   @db.Char(36)

  category   String   @db.VarChar(100)
  description String
  amount     Decimal  @db.Decimal(12, 2)
  expenseDate DateTime

  // Relations
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  client     B2BClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buildingId])
  @@index([clientId])
  @@index([expenseDate])
}

// ============================================
// Support Tickets
// ============================================

model SupportTicket {
  id         String   @id @default(uuid()) @db.Char(36)
  clientId   String   @db.Char(36)

  ticketType TicketType
  priority   TicketPriority @default(MEDIUM)
  category   String?  @db.VarChar(100)

  title      String   @db.VarChar(255)
  description String

  submittedById String  @db.Char(36)
  submittedByEmail String @db.VarChar(255)

  assignedToId String? @db.Char(36)

  status     TicketStatus @default(OPEN)
  resolutionNotes String?
  resolvedAt DateTime?

  // Relations
  client     B2BClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  submittedBy User @relation("submittedBy", fields: [submittedById], references: [id], onDelete: Cascade)
  assignedTo BuildHubAdminUser? @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([ticketType])
  @@index([priority])
}

enum TicketType {
  TECHNICAL
  OPERATIONAL
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ============================================
// Complex Amenities (AdComplex only)
// ============================================

model ComplexAmenity {
  id       String   @id @default(uuid()) @db.Char(36)
  clientId String   @db.Char(36)

  name     String   @db.VarChar(255)
  description String?
  location String?

  isAvailable Boolean @default(true)

  // Relations
  client   B2BClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}
